        ['AGVP', "${data_dir}/data/AGVP/vcf_banganda_zulu_ethiopia_raw/RAW/banganda_zulu_ethiopia_%s.vcf.gz", "${data_dir}/data/AGVP/banganda_zulu_ethiopia_updated.sample", "Amhara,Baganda,Gumuz,Oromo,Somali,Wolayta,Zulu"],
        // ['HGDP', "${data_dir}/data/HGDP/VCF/CHRS/hgdp-san-exome-variants_updated.chr%s_biall_phased.vcf.gz", "${data_dir}/data/HGDP/hgdp-san-exome-variants.sample", "SAN"],
    ]
