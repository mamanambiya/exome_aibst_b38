    clinicalVariants_db                 = "${pxg_dataset_dir}/Clinically_relavent_PGX_variants_Prof_Collen_pos.tsv"
//    clinicalVariants_db                 = "${pxg_dataset_dir}/clinicalAnnotations_07_2017.csv"
    pgxClinicalLevel1                   = "${pxg_dataset_dir}/pgxClinicalLevel1_04_2018_rsID_AIBST_forR.csv"
    cadd_annotations                    = "${pxg_dataset_dir}/pgx1000GP.VEP.cadd.annotations.tsv"
    //pgx_variants                        = "${pxg_dataset_dir}/ALL_genes_variants_final.tsv"
    pgx_variants                        = "${pxg_dataset_dir}/GRCh38/Extended_PGX_gene_AIBST_exome_final_slop25_unique_GRCh38.bed"
     gene_lists = [
          ["ext_pgx_variants", "${pxg_dataset_dir}/GRCh38/Extended_PGX_gene_AIBST_exome_final_slop25_unique_GRCh38.bed"],
    ]
//    gene_regions                        = "${pxg_dataset_dir}/GRCh38/PGX_gene_coordinates_AIBST_exome_final_GRCh38.bed"
//    gene_regions_slop                   = "${pxg_dataset_dir}/GRCh38/Extended_PGX_gene_AIBST_exome_final_slop25_unique_GRCh38.bed"
    gene_regions_slop                   = "${pxg_dataset_dir}/GRCh38/PGX_gene_coordinates_AIBST_exome_final_GRCh38.bed"
    strict_mask_whole_genome_final      = "${pxg_dataset_dir}/20141020.strict_mask.whole_genome_final.bed"
