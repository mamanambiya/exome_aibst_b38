    dataset_groups = [
        [ "KNK_NGH_SAN", "KNK,NGH,SAN" ],
        [ "KNM_YRI", "KNM,YRI" ],
        ["AFR_ALL", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWD,ZWS,ACB,ASW,LWK,ESN,GWD,MSL,YRI,Amhara,Baganda,Gumuz,Oromo,Somali,Wolayta,Zulu,SAN"],
        // ["ALL", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWD,ZWS,ACB,ASW,LWK,ESN,GWD,MSL,YRI,Amhara,Baganda,Gumuz,Oromo,Somali,Wolayta,Zulu,SAN,CEU,GBR,FIN,TSI,IBS"],
        // ["AIBST", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWD,ZWS"],
        // ["AIBST_NO_ZWD", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWS"],
        // ["AIBST_NO_ZWD_HENN_HGDP", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWS,SAN"],
        // ["AIBST_HENN_HGDP", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWD,ZWS,SAN"],
        // ["AIBST_AGVP", "KNK,KNL,KNM,KNP,NGH,NGI,NGY,SAV,TZA,TZB,ZWD,ZWS,Amhara,Baganda,Gumuz,Oromo,Somali,Wolayta,Zulu"],
        // ["EUR_KG", "CEU,GBR,FIN,TSI,IBS"]
    ]
        // KHOESAN_SAN_YRI = "KHOESAN,SAN,YRI"
