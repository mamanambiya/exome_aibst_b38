    //awk 'NR>1 {print $1"	"$2"	"$3}' GRCh37GenomicSuperDup.tab | sed s/^chr//g > GRCh38/GRCh38GenomicSuperDup.bed
    GRCh37GenomicSuperDup   = "${pxg_dataset_dir}/GRCh38/GRCh38GenomicSuperDup.bed"

    gatk                    = "java -Xmx15g -jar bin/GenomeAnalysisTK.jar "
    ref_genome              = "${reference_dir}/gatk_bundle/human_genomes/GRCh38/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna" // must have .fasta and .dict From ftp://ftp.broadinstitute.org/bundle/b37/
    dbsnp_sites             = "${reference_dir}/dbSNP/b151/b38/All_20180418.vcf.gz" //
    hapmap_sites            = "${reference_dir}/gatk_bundle/hg38/hapmap_3.3.hg38.vcf.gz" // From ftp://ftp.broadinstitute.org/bundle/b37/
    omni_kg_sites           = "${reference_dir}/gatk_bundle/hg38/1000G_omni2.5.hg38.vcf.gz" // From ftp://ftp.broadinstitute.org/bundle/b37/
    kg_sites                = "${reference_dir}/gatk_bundle/hg38/1000G_phase1.snps.high_confidence.hg38.vcf.gz" // From ftp://ftp.broadinstitute.org/bundle/b37/
    mills_sites             = "${reference_dir}/gatk_bundle/hg38/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz" // From ftp://ftp.broadinstitute.org/bundle/b37/
//     Genetic map for Eagle
    genetic_map             = "${reference_dir}/genetic_map/genetic_map_hg38_withX.txt.gz"

    // From "http://www.genome.gov/admin/gwascatalog.txt" lift over to b37 using crossmap
    gwascat_b38       = "${reference_dir}/gwascat/GRCh38/gwas_catalog_v1.0_associations_GRCh38.tsv"

    // Clinvar from ftp://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh37/clinvar_20200224.vcf.gz
    clinvar           = "${reference_dir}/clinvar/GRCh38/clinvar_GRCh38_latest.vcf.gz"

    //
    cosmic                  = "${reference_dir}/cosmic/GRCh38/CosmicCodingMuts_v99_GRCh38.vcf.gz"

    mafs_annotations = [
        // MAFs other databases
        ["KG", "${reference_dir}/pop_mafs/KG/KG.chr%s.mafs"],
        ["gnomAD", "${reference_dir}/pop_mafs/gnomAD/gnomAD.chr%s.mafs"],
        ["ExAC", "${reference_dir}/pop_mafs/ExAC/ExAC.chr%s.mafs"],
        ["agvp", "${reference_dir}/pop_mafs/agvp/agvp.chr%s.mafs"],
        ["TOPMED", "${reference_dir}/pop_mafs/topmed/topmed.chr%s.mafs"],
        ["sahgp", "${reference_dir}/pop_mafs/sahgp/sahgp.chr%s.mafs"],

        // ["trypanogen", "${reference_dir}/pop_mafs/trypanogen.all.phased.frq.mamana_ready_"], //TODO causing issues, check later
//        other          = "${reference_dir}/pop_mafs/dbNSFPv3.5a_b37_af_final.frq"
    ]

    drug_disease_variants = [
        ['anthracyclines', "${pxg_dataset_dir}/drug-disease/anthracyclines.csv"],
        ['Distribution', "${pxg_dataset_dir}/drug-disease/Distribution.csv"],
        ['antiretroviral', "${pxg_dataset_dir}/drug-disease/antiretroviral.csv"],
        ['cisplatin', "${pxg_dataset_dir}/drug-disease/cisplatin.csv"],
        ['fluorouracil', "${pxg_dataset_dir}/drug-disease/fluorouracil.csv"],
        ['vincristine', "${pxg_dataset_dir}/drug-disease/vincristine.csv"],
        ['table9', "${pxg_dataset_dir}/drug-disease/table9.csv"],
    ]

    // mafs_annotations_afr{
    //     // MAFs other databases
    //     KG             = "${reference_dir}/REF_PANELS/1000G/Allele_Freqs/KG_afr.mafs"
    //     gnomAD         = "${reference_dir}/gnomAD/genomes/Allele_Freqs/gnomAD_afr.mafs"
    //     ExAC           = "${reference_dir}/gnomAD/exomes/Allele_Freqs/ExAC_afr.mafs"
    //     trypanogen     = "${reference_dir}/pop_mafs/trypanogen.all.phased.frq.mamana_ready_"
    //     sahgp          = "${reference_dir}/pop_mafs/sahgp.frq.frq.mamana_ready_"
    //     agvp           = "${reference_dir}/pop_mafs/agv3f.frq.frq.mamana_ready_"
    // }


    // ancestral alignments for ancestral allele annotation
    genomedata_path         = "${reference_dir}/genomedata"

}

process {
    withLabel : "small"{
        memory = { 8.GB * task.attempt }
    }
    withLabel : "medium"{
        memory = { 18.GB * task.attempt }
        time = { 24.h }
    }
    withLabel : "bigmem"{
        // memory = { 28.GB * task.attempt }
        memory = { if (task.attempt <= 3 ) { 28.GB * task.attempt } else { 28.GB * 3 } }
        time = { 48.h }
    }
    withLabel: "extrabig" {
        container       = 'docker://quay.io/mypandos/pgx_tools'
        memory          = { 30.GB }
        time            = { 72.h }
    }

}
executor{
    jobName = { "$task.tag" }
    stageOutMode = "rsync"
}
profiles {
    // For execution on a local machine, no containerization. -- Default
    standard {
        process.executor = 'local'
    }
    local {
        executor {
            name = "local"
            cpus = 1
        }
        docker {
            enabled = false
        }
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "/scratch/users/mamana/singularity-containers"
        process.container = 'docker://quay.io/mypandos/pgx_tools'
        singularity.runOptions = " -B ${params.scratch_dir} " // add any paths that need   to be mounted here
    }
    slurm {
        executor{
            queueSize = 100
        }
        process{
            executor        = 'slurm'
            queue           = 'Main'
            memory          = { 30.GB * task.attempt }
            cpus            = { if (task.attempt > 2 ) { 3 } else { 1 } }
            time            = { 72.h }
            maxRetries      = 3
            maxErrors       = 10000
            errorStrategy   = 'retry'
            clusterOptions  = { "--mail-user=mbymam001@myuct.ac.za --account b56-cbio-001-ag" }
        }
        process.clusterOptions = '--account b56-cbio-001-ag'
    }
}

workflow.onComplete = {
    println "========================================="
    println "Pipeline completed at: $workflow.complete"
    println "Execution status: ${ workflow.success ? 'OK' : 'failed' }"
}
